<style>
  :root{
    --ground:#14120f;
    --surface:#1c1914;
    --surface-2:#221e18;
    --line:#3a352b;
    --gold:#e3a53c;
    --gold-dim:#9c7530;
    --text:#efe9dd;
    --muted:#9c9384;
    --caution:#c96a44;
    --caution-dim:#4a3327;
    --good:#7f9e78;
    --good-dim:#33402f;
    --serif: Georgia, 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', serif;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', ui-sans-serif, Roboto, Helvetica, Arial, sans-serif;
    --mono: ui-monospace, 'Cascadia Mono', 'SF Mono', Consolas, monospace;
  }

  .page{
    background: var(--ground);
    color: var(--text);
    font-family: var(--sans);
    max-width: 780px;
    margin: 0 auto;
    padding: 0 0 5rem 0;
    line-height: 1.6;
  }
  .page *{ box-sizing: border-box; }

  /* ---------- Slate header ---------- */
  .slate{
    padding: 3.2rem 2rem 2.4rem;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(ellipse 480px 260px at 50% -40px, rgba(227,165,60,0.14), transparent 70%),
      var(--ground);
    text-align: center;
  }
  .slate-eyebrow{
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .slate h1{
    font-family: var(--serif);
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    margin: 0 0 0.6rem;
    text-wrap: balance;
    color: var(--text);
  }
  .slate-sub{
    font-size: 1.05rem;
    color: var(--muted);
    margin: 0 0 1.6rem;
  }
  .slate-meta{
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  .slate-meta span{ position: relative; }
  .slate-meta span + span::before{
    content: '';
    position: absolute;
    left: -0.85rem;
    top: 50%;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--gold-dim);
    transform: translateY(-50%);
  }

  section{ padding: 2.6rem 2rem 0; }
  h2{
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 1.2rem;
  }
  p{ margin: 0 0 1rem; color: var(--text); }
  .lede{ color: var(--muted); font-size: 1rem; max-width: 62ch; }

  /* ---------- Callouts ---------- */
  .verdict{
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--caution-dim);
    border-left: 3px solid var(--caution);
    padding: 1.1rem 1.3rem;
    margin-bottom: 1.6rem;
  }
  .verdict-tag{
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--caution);
    white-space: nowrap;
    padding-top: 0.15rem;
  }
  .verdict p{ margin: 0; color: var(--text); font-size: 0.96rem; }
  .verdict strong{ color: var(--text); }

  .table-wrap{ overflow-x: auto; margin-bottom: 1.8rem; }
  table{
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    min-width: 480px;
  }
  thead th{
    text-align: left;
    font-family: var(--sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 0.8rem 0.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  tbody td{
    padding: 0.75rem 0.8rem 0.75rem 0;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    color: var(--text);
  }
  tbody tr:last-child td{ border-bottom: none; }
  .cost{ font-family: var(--mono); font-variant-numeric: tabular-nums; color: var(--gold); white-space: nowrap; }
  .row-note{ color: var(--muted); font-size: 0.85rem; }
  .row-fit td:first-child{ color: var(--good); font-weight: 600; }

  .recommend{
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: 1.1rem 1.3rem;
    font-size: 0.94rem;
  }
  .recommend .label{
    display:block;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--good);
    margin-bottom: 0.4rem;
  }
  .recommend.warn .label{ color: var(--caution); }
  .recommend.warn{ border-color: var(--caution-dim); }

  /* ---------- Timeline ---------- */
  .timeline{ position: relative; }
  .phase{
    position: relative;
    padding: 0 0 0 2rem;
    margin-bottom: 2.2rem;
    border-left: 1px solid var(--line);
  }
  .phase:last-child{ margin-bottom: 0; }
  .phase::before{
    content: '';
    position: absolute;
    left: -5px;
    top: 0.35rem;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--ground);
    border: 2px solid var(--gold);
  }
  .phase.sub::before{ border-color: var(--gold-dim); width:7px; height:7px; left:-4px; }
  .phase-head{
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 0.9rem;
    margin-bottom: 0.5rem;
  }
  .phase-num{
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--gold-dim);
    letter-spacing: 0.05em;
  }
  .phase-title{
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text);
  }
  .phase.sub .phase-title{ font-size: 1.05rem; }
  .phase-meta{
    display:flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-family: var(--mono);
    font-size: 0.76rem;
    color: var(--muted);
    margin-bottom: 0.7rem;
  }
  .chip{
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.22rem 0.55rem;
    border: 1px solid;
  }
  .chip.you{ color: var(--good); border-color: var(--good-dim); background: rgba(127,158,120,0.08); }
  .chip.delegate{ color: var(--gold); border-color: var(--gold-dim); background: rgba(227,165,60,0.08); }
  .phase ul{ margin: 0.6rem 0 0; padding-left: 1.1rem; color: var(--text); font-size: 0.94rem; }
  .phase li{ margin-bottom: 0.35rem; }
  .phase li::marker{ color: var(--gold-dim); }

  /* ---------- Learn / Own lists ---------- */
  .card-list{
    display: grid;
    gap: 0.7rem;
  }
  .card-item{
    display: flex;
    gap: 0.9rem;
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.85rem 1rem;
  }
  .card-item .mark{
    font-family: var(--mono);
    color: var(--gold);
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .card-item p{ margin: 0; font-size: 0.92rem; color: var(--text); }
  .card-item .sub{ color: var(--muted); font-size: 0.85rem; margin-top: 0.2rem; }

  footer{
    margin: 3rem 2rem 0;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
  }
  footer strong{ color: var(--text); }

  @media (prefers-reduced-motion: no-preference){
    .phase, .verdict, .card-item{ transition: border-color 0.2s ease; }
  }
</style>

<div class="page">

  <header class="slate">
    <div class="slate-eyebrow">Production Roadmap</div>
    <h1>Spotlight Enosis</h1>
    <p class="slate-sub">Path to a free-launch MVP — built by you, with Claude Code</p>
    <div class="slate-meta">
      <span>Updated 2 Jul 2026</span>
      <span>Self-build with Claude Code</span>
      <span>Target ship: mid-Aug 2026</span>
